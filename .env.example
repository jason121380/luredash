FB_APP_ID=your_app_id
FB_APP_SECRET=your_app_secret
FB_ACCESS_TOKEN=your_long_lived_access_token
FB_API_VERSION=v21.0
# Read-only 費用中心匯出 API 的 token（機器對機器，給 lurefin 每月同步）。
# GET /api/cost-center 需要 Authorization: Bearer <此值>。
# 用 `openssl rand -hex 32` 產生一組長亂數；勿 commit 真實值。
AD_SPEND_API_TOKEN=
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview
DATABASE_URL=postgresql://user:password@host:port/dbname
# Long random string used to sign browser sessions after FB login.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
# Optional: signed browser session lifetime in seconds (default: 7 days).
SESSION_TTL_SECONDS=604800

# ── LINE push scheduler ─────────────────────────────────────────────
# Messaging API channel on LINE Developers Console. The access token
# authorises `POST /v2/bot/message/push`. The channel secret is used
# to verify `X-Line-Signature` on the /api/line/webhook route.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# Set to 1 in local dev to skip real LINE API calls — the push helper
# prints the payload to stdout instead, so the scheduler loop can be
# exercised end-to-end without a real channel.
LINE_MOCK=0
# IANA zone used to interpret the HH:MM stored on each push config.
# Zeabur containers default to UTC; override per project deployment.
SCHEDULER_TZ=Asia/Taipei
# Public origin of the deployed app — used to build links inside LINE
# flex pushes and billing redirects.
PUBLIC_SITE_URL=https://luredash.lure.com.tw

# ── Billing / Polar.sh ──────────────────────────────────────────────
# Polar.sh handles checkout, trials, and billing. Get these from
# https://polar.sh after creating an organization + 3 products
# (Basic / Plus / Max monthly subscriptions).
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID_BASIC=
POLAR_PRODUCT_ID_PLUS=
POLAR_PRODUCT_ID_MAX=

# ── 電子發票 / 藍新 ezPay ────────────────────────────────────────────
# 從 ezPay 商店後台取得。HashKey 32 碼、HashIV 16 碼(AES-256-CBC 用)。
# EZPAY_API_BASE 預設測試站；正式上線改成 https://inv.ezpay.com.tw 並換正式金鑰。
# EZPAY_MOCK=1 時只印出加密前的參數、不真的呼叫 ezPay(本機開發免金鑰)。
EZPAY_MERCHANT_ID=
EZPAY_HASH_KEY=
EZPAY_HASH_IV=
EZPAY_API_BASE=https://cinv.ezpay.com.tw
EZPAY_MOCK=0
